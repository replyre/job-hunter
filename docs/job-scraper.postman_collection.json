            "url": {
              "raw": "{{baseUrl}}/api/export/sheets?min_score=40&mode=replace&sheet_name=Jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "export", "sheets"],
              "query": [
                { "key": "min_score", "value": "40" },
