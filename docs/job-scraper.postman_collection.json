{
  "info": {
    "name": "Job Scraper API",
    "description": "Postman collection for the Job Scraper FastAPI backend (main.py v2.0.0). Base URL default: http://127.0.0.1:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "job-scraper-collection-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "company_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "outreach_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "query_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs?min_score=0&limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"],
              "query": [
                { "key": "source", "value": "", "disabled": true, "description": "Partial match on source name" },
                { "key": "status", "value": "new", "disabled": true, "description": "new | reviewed | applied | stale" },
                { "key": "min_score", "value": "0", "description": "0-100" },
                { "key": "search", "value": "", "disabled": true, "description": "Free text on title/company/description" },
                { "key": "location", "value": "", "disabled": true },
                { "key": "tech", "value": "", "disabled": true, "description": "e.g. python, django" },
                { "key": "india_friendly", "value": "yes", "disabled": true, "description": "yes | maybe | no" },
                { "key": "company_domain", "value": "", "disabled": true },
                { "key": "limit", "value": "50", "description": "1-500" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{job_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "{{job_id}}"]
            }
          }
        },
        {
          "name": "Update job status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{job_id}}/status?status=applied",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "{{job_id}}", "status"],
              "query": [
                { "key": "status", "value": "applied", "description": "new | reviewed | applied | stale" }
              ]
            }
          }
        },
        {
          "name": "Toggle mark-for-email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{job_id}}/mark-for-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "{{job_id}}", "mark-for-email"]
            }
          }
        },
        {
          "name": "List marked jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/marked",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "marked"]
            }
          }
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats"]
            }
          }
        },
        {
          "name": "Sources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sources",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sources"]
            }
          }
        },
        {
          "name": "Trigger collection",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/collect",
              "host": ["{{baseUrl}}"],
              "path": ["api", "collect"]
            },
            "description": "Runs full collection pipeline (job boards + company crawl). Long-running."
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "List companies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies?limit=200&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies"],
              "query": [
                { "key": "ats_platform", "value": "greenhouse", "disabled": true, "description": "greenhouse | lever | ashby | workable | unknown" },
                { "key": "crawl_status", "value": "active", "disabled": true, "description": "active | paused" },
                { "key": "india_friendly", "value": "yes", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "limit", "value": "200" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Add company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"domain\": \"acme.com\",\n  \"careers_url\": \"https://acme.com/careers\",\n  \"ats_platform\": \"greenhouse\",\n  \"ats_slug\": \"acme\",\n  \"founded_year\": 2015,\n  \"employee_count\": \"50-200\",\n  \"tags\": \"saas,b2b\",\n  \"india_friendly\": \"maybe\",\n  \"notes\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/companies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies"]
            }
          }
        },
        {
          "name": "Update company",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"domain\": \"acme.com\",\n  \"careers_url\": \"https://acme.com/careers\",\n  \"ats_platform\": \"greenhouse\",\n  \"ats_slug\": \"acme\",\n  \"founded_year\": 2015,\n  \"employee_count\": \"50-200\",\n  \"tags\": \"saas,b2b\",\n  \"india_friendly\": \"yes\",\n  \"notes\": \"updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{company_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{company_id}}"]
            }
          }
        },
        {
          "name": "Pause company (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{company_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{company_id}}"]
            }
          }
        },
        {
          "name": "Activate company",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{company_id}}/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{company_id}}", "activate"]
            }
          }
        },
        {
          "name": "Company stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "stats"]
            }
          }
        },
        {
          "name": "Seed companies (73 curated)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/seed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "seed"]
            }
          }
        },
        {
          "name": "Mega-seed companies (250+)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/mega-seed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "mega-seed"]
            }
          }
        },
        {
          "name": "Crawl one company",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{company_id}}/crawl",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{company_id}}", "crawl"]
            }
          }
        },
        {
          "name": "Crawl all companies",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/crawl",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "crawl"]
            }
          }
        },
        {
          "name": "Detect ATS for domain",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/detect-ats?domain=stripe.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "detect-ats"],
              "query": [
                { "key": "domain", "value": "stripe.com" }
              ]
            }
          }
        },
        {
          "name": "Bulk discover companies",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/companies/discover?sources=yc,remoteintech,wwr&detect_ats=true&min_team_size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "discover"],
              "query": [
                { "key": "sources", "value": "yc,remoteintech,wwr", "description": "Comma-separated: yc,remoteintech,wwr" },
                { "key": "detect_ats", "value": "true", "description": "Slow if true" },
                { "key": "min_team_size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
